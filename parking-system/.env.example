# Supabase — SERVER ONLY. Never expose the service role key to the browser.
# For local dev, get these from `npx supabase status` after `npm run db:start`.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret required in the `x-job-secret` header to trigger job routes
# (POST /api/jobs/friday-allocation).
JOB_TRIGGER_SECRET=

# Vercel Cron bearer secret (Phase 4 Slice C). When set, Vercel Cron invokes the
# dispatcher with `Authorization: Bearer $CRON_SECRET`; the dispatch + outbox-status
# routes accept EITHER this or x-job-secret. Leave empty if you drive the dispatcher
# only via an external scheduler using JOB_TRIGGER_SECRET.
CRON_SECRET=

# Auto-finalize fallback grace window (days). A past 'open' weekly_event is auto
# settled + finalized only once its Sunday is older than (today − this many days),
# measured on the Asia/Taipei business date. Defaults to 2 when unset/invalid.
AUTO_FINALIZE_GRACE_DAYS=2

# Notification dispatcher (Phase 4). Selects the LINE push transport EXPLICITLY —
# no silent fallback. Must be 'mock' (dev/CI: pretend-deliver) or 'line' (real LINE
# Messaging API). 'line' REQUIRES LINE_CHANNEL_ACCESS_TOKEN below or the job fails
# fast (never marks rows sent without delivering). Unset/other value also fails fast.
NOTIFICATION_TRANSPORT=mock
# LINE Messaging API channel access token — SERVER ONLY. Required when
# NOTIFICATION_TRANSPORT=line. Leave empty for mock.
LINE_CHANNEL_ACCESS_TOKEN=
