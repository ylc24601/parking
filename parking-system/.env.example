# Supabase — SERVER ONLY. Never expose the service role key to the browser.
# For local dev, get these from `npx supabase status` after `npm run db:start`.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret required in the `x-job-secret` header to trigger job routes
# (POST /api/jobs/friday-allocation).
JOB_TRIGGER_SECRET=

# Vercel Cron bearer secret (Phase 4 Slice C). When set, Vercel Cron invokes the
# dispatcher with `Authorization: Bearer $CRON_SECRET`; the dispatch + outbox-status
# routes accept EITHER this or x-job-secret. Leave empty if you drive the dispatcher
# only via an external scheduler using JOB_TRIGGER_SECRET.
CRON_SECRET=

# Auto-finalize fallback grace window (days). A past 'open' weekly_event is auto
# settled + finalized only once its Sunday is older than (today − this many days),
# measured on the Asia/Taipei business date. Defaults to 2 when unset/invalid.
AUTO_FINALIZE_GRACE_DAYS=2

# Notification dispatcher (Phase 4). Selects the LINE push transport EXPLICITLY —
# no silent fallback. Must be 'mock' (dev/CI: pretend-deliver) or 'line' (real LINE
# Messaging API). 'line' REQUIRES LINE_CHANNEL_ACCESS_TOKEN below or the job fails
# fast (never marks rows sent without delivering). Unset/other value also fails fast.
NOTIFICATION_TRANSPORT=mock
# LINE Messaging API channel access token — SERVER ONLY. Required when
# NOTIFICATION_TRANSPORT=line. Leave empty for mock.
LINE_CHANNEL_ACCESS_TOKEN=

# LINE webhook channel secret (Phase 5A) — SERVER ONLY. Used to verify `x-line-signature`
# (HMAC-SHA256 over the raw body) on POST /api/line/webhook. Distinct from the access token
# above: the secret verifies inbound webhooks; the token authorizes outbound sends. Required
# for the webhook to accept any event — an unset secret fails every signature closed.
LINE_CHANNEL_SECRET=

# Outbound send lock (Phase 5A posture). The Phase 5A webhook is capture-only and never sends,
# so nothing reads this yet; it documents the go-live safety lock (see docs/go-live-readiness.md)
# and gates the future single manually-triggered test push. Keep 'false' until a specific,
# consenting operator test. Production reservation notifications stay driven by
# NOTIFICATION_TRANSPORT above, NOT by this flag.
LINE_SEND_ENABLED=false

# Outbox health-alert thresholds (Phase 4 Slice F). GET /api/internal/jobs/outbox-alert
# (and `npm run job:outbox-alert`) return unhealthy (HTTP 503 / non-zero exit) when breached,
# so an external monitor/cron can alert. Sensitive pilot defaults below: ANY terminal failed
# row or stale processing lease alerts, and a DUE backlog older than 15 min means the scheduler
# isn't draining. Raise these once a steady state is known. Missing/invalid → default.
OUTBOX_ALERT_FAILED_MAX=0
OUTBOX_ALERT_STALE_MAX=0
OUTBOX_ALERT_PENDING_STALE_MINUTES=15

# Binding PII retention window (Phase 8 Slice 7, docs/binding-ops.md「PII 保留」).
# pending_binding rows decided (approved/rejected) at least this many days ago get
# claimed_phone / claimed_name / submitted_code cleared by the retention job
# (GET /api/internal/jobs/redact-binding-pii, scheduled daily; CLI `npm run
# job:redact-binding-pii` previews). Default 90; values below the 30-day floor or
# invalid fall back to 90 (fail-safe: never delete earlier because of a typo).
BINDING_PII_RETENTION_DAYS=90
